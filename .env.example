# --- ANTHROPIC ---
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# --- TELEGRAM ---
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here
TELEGRAM_PORTFOLIO_CHANNEL_ID=your_public_channel_id_here

# --- BRANDING & PERSONA ---
# Use these to brand each client's engine instance
AI_PERSONA=You are a thought leader in the AI space...
BRAND_VOICE=Mentor talking to a friend...
COMPANY_NAME=itappens.ai
FOOTER_BRANDING=— Sadish Sugumaran
REEL_CTA=Limited slots for March automation coaching. Link in bio.

# --- BUFFER ---
# You can use one account for everything OR two accounts to stay on the FREE tier.
BUFFER_PERSONAL_ACCESS_TOKEN=your_personal_account_token
BUFFER_AGENCY_ACCESS_TOKEN=your_agency_account_token
# Fallback if personal/agency tokens are missing:
BUFFER_ACCESS_TOKEN=your_legacy_token
BUFFER_LINKEDIN_PERSONAL_PROFILE_ID=your_personal_id_here
BUFFER_LINKEDIN_AGENCY_PROFILE_ID=your_agency_id_here
BUFFER_INSTAGRAM_PROFILE_ID=your_instagram_id_here
BUFFER_YOUTUBE_PROFILE_ID=your_youtube_profile_id

# --- GOOGLE SHEETS ---
GOOGLE_SHEET_ID=your_google_sheet_id_here
GOOGLE_SHEET_NAME=Sheet1
GOOGLE_SHEET_RANGE=A:E

# --- BYPASS & PAYMENTS ---
# SKIP_PAYMENT=True enables auto-login and bypasses subscription checks
SKIP_PAYMENT=False
# AUTH0_DOMAIN should be empty for dev auto-login
AUTH0_DOMAIN=
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
RAZORPAY_PLAN_STARTER_ID=
RAZORPAY_PLAN_PRO_ID=
